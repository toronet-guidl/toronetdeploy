{
  "name": "toronetdeploy",
  "version": "3.1.2",
  "description": "Deploy smart contracts to ToroNet",
  "main": "src/index.js",
  "module": "src/index.mjs",
  "bin": {
    "toronetdeploy": "src/cli.js"
  },
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.mjs"
    }
  },
  "scripts": {
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "ci": "npm run check-format && npm run test",
    "prepublishOnly": "npm run ci",
    "create-changeset": "npx changeset",
    "local-release": "npx changeset version && npm publish",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "toronet",
    "smart-contracts",
    "deployment"
  ],
  "author": "emmo00",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toronet-guidl/toronetdeploy.git"
  },
  "dependencies": {
    "ethereum-cryptography": "^2.1.3",
    "solc": "^0.8.34",
    "torosdk": "^0.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "prettier": "^3.8.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
